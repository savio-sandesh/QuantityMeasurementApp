  "components": {
    "schemas": {
      "QuantityDTO": {
        "required": [
          "measurementType",
          "unit",
          "value"
        ],
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "format": "double"
          },
          "unit": {
            "minLength": 1,
            "type": "string"
          },
          "measurementType": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "QuantityInputDTO": {
        "required": [
          "thatQuantityDTO",
          "thisQuantityDTO"
        ],
        "type": "object",
        "properties": {
          "thisQuantityDTO": {
            "$ref": "#/components/schemas/QuantityDTO"
          },
          "thatQuantityDTO": {
            "$ref": "#/components/schemas/QuantityDTO"
          },
          "targetQuantityDTO": {
            "$ref": "#/components/schemas/QuantityDTO"
          }
        },
        "additionalProperties": false
      },
      "UserLoginDTO": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserRegisterDTO": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "JWT Authorization header using the Bearer scheme. Enter 'Bearer' followed by your token. Example: Bearer eyJhbGciOi...",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "components/securitySchemes#/components/securitySchemes/Bearer": [ ]
    }
  ],
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "QuantityMeasurement"
    }
  ]
}
